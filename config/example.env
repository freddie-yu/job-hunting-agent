# ================================================================
# Daily Job Agent - 环境变量配置示例
# ================================================================
# 注意: 以下变量需要在 n8n 中配置为 Credentials 或 Config 节点变量
# 此文件仅作为参考，请勿在代码中直接引用此文件
# ================================================================

# =====================
# Google Drive 配置
# =====================
# 你的 PDF 简历文件在 Google Drive 中的 File ID
# 获取方式: 在 Google Drive 中右键文件 → "Get link" → 提取 ID 部分
# 例如链接 https://drive.google.com/file/d/1aBcDeFgHiJkLmNoPqR/view
# 则 File ID 为: 1aBcDeFgHiJkLmNoPqR
GOOGLE_DRIVE_FILE_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# Google Cloud Service Account JSON 密钥路径
# 需要在 n8n 中配置 Google Drive OAuth2 凭证
# 详见: https://docs.n8n.io/integrations/builtin/credentials/google/
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# =====================
# LinkedIn / Apify 配置
# =====================
# Apify API Token
# 获取方式: https://console.apify.com/account/integrations
# 需要在 n8n 中配置为 HTTP Header Auth 凭证
# Header Name: Authorization
# Header Value: Bearer YOUR_APIFY_TOKEN
APIFY_API_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LinkedIn 搜索关键词（逗号分隔）
# 每个关键词将作为独立搜索查询
LINKEDIN_SEARCH_KEYWORDS=Software Engineer,Backend Developer,Full Stack Developer

# LinkedIn 搜索地点
LINKEDIN_LOCATION=Australia

# 排除关键词（标题中包含这些词的职位将被过滤掉）
EXCLUDE_KEYWORDS=intern,junior,graduate,trainee

# =====================
# AI 评分配置
# =====================
# Anthropic Claude API Key
# 获取方式: https://console.anthropic.com/settings/keys
# 需要在 n8n 中配置为 HTTP Header Auth 凭证
# Header Name: x-api-key
# Header Value: YOUR_CLAUDE_API_KEY
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI 模型选择（推荐 claude-sonnet-4-20250514 以平衡效果与成本）
CLAUDE_MODEL=claude-sonnet-4-20250514

# AI 评分批次大小（每次发送几个职位给 AI 评分）
# 建议 3-5，太大可能导致上下文过长
AI_BATCH_SIZE=5

# 最低分数过滤线（低于此分数的职位不会出现在邮件中）
# 设为 0 表示不过滤
MIN_OVERALL_SCORE=0

# =====================
# 邮件配置
# =====================
# 接收每日报告的邮箱地址
RECIPIENT_EMAIL=your.email@gmail.com

# Gmail OAuth2 凭证
# 需要在 n8n 中配置 Gmail OAuth2
# 详见: https://docs.n8n.io/integrations/builtin/credentials/google/
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxx

# =====================
# 运行参数
# =====================
# 最终发送的职位数量（Top N）
TOP_N_JOBS=15

# 时区设置（n8n 实例级别）
TIMEZONE=Australia/Sydney

# =====================
# 备选方案 - RapidAPI LinkedIn（当 Apify 不可用时）
# =====================
# RapidAPI Key（如果使用 RapidAPI 的 LinkedIn Jobs Search API）
# 获取方式: https://rapidapi.com/jaypat87/api/linkedin-jobs-search
# RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RAPIDAPI_HOST=linkedin-jobs-search.p.rapidapi.com
